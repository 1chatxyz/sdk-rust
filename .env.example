# Envoy gateway base URL (gRPC-Web). Already the gateway — no proxy setup needed.
API_1CHAT_URL=https://gateway.example.com

# Bot credentials (required)
TENANT_ID=
BOT_TOKEN=

# Optional: bot identity for self-filter / mention matching
ONECHAT_USER_ID=
ONECHAT_USERNAME=

# Optional: group id for local send/stream examples
CHANNEL_ID_TEST=

# crates.io publish token — use as GitHub Actions secret, never commit real values
CARGO_REGISTRY_TOKEN=
